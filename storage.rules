rules_version = '2';

// ==========================================
// Firebase Storage 보안 규칙
// ==========================================
//
// 원칙: 자기 파일만. 남의 uid 경로는 읽기도 쓰기도 막는다.
//
// 여기 올라가는 것은 영수증 사진과 음성 녹음이다. 둘 다 사적인 자료다.
// 규칙이 열려 있으면 URL만 알면 남이 읽을 수 있으므로,
// 경로의 uid와 로그인한 uid가 같을 때만 허용한다.
//
// 배포:
//   firebase deploy --only storage
// (firebase.json의 storage.rules가 이 파일을 가리켜야 한다)

service firebase.storage {
  match /b/{bucket}/o {

    // 사용자별 업로드 영역
    match /users/{uid}/uploads/{fileName} {

      function isOwner() {
        return request.auth != null && request.auth.uid == uid;
      }

      // 읽기: 본인만.
      // 서버(API 라우트)는 클라이언트가 넘겨준 download URL로 받아간다.
      // 그 URL에는 토큰이 붙어 있어 이 규칙과 무관하게 동작하므로,
      // 여기서는 사람이 직접 접근하는 경로만 막으면 된다.
      allow read: if isOwner();

      // 쓰기: 본인만, 그리고 크기·형식 제한.
      //
      // 크기를 규칙에서도 막는 이유:
      // 클라이언트 코드에서만 막으면 우회된다. Storage는 우리 서버를
      // 거치지 않으므로, 여기서 안 막으면 무제한 업로드가 가능하다.
      // (= 요금 폭탄)
      allow write: if isOwner()
                   && request.resource.size < 25 * 1024 * 1024
                   && (
                        request.resource.contentType.matches('image/.*')
                        || request.resource.contentType.matches('audio/.*')
                        || request.resource.contentType.matches('video/mp4')
                      );

      // 삭제: 본인만.
      // 분석이 끝나면 클라이언트가 지운다. 안 지우면 고아 파일이 쌓인다.
      allow delete: if isOwner();
    }

    // 그 외 경로는 전부 차단
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
